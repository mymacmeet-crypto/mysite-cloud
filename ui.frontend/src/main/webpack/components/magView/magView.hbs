<div class="mag-view" data-component="magview" data-view-type="{{viewType}}">

  {{#if sectionTitle}}
    <div class="mag-view-header">
      <h2 class="mag-view-title">{{sectionTitle}}</h2>
    </div>
  {{/if}}

  {{#if items}}
    {{#if (eq viewType "card")}}
      <!-- Card Grid Layout -->
      <div class="mag-view-grid">
        {{#each items}}
          <div class="mag-view-card">
            {{#if fileReference}}
              <div class="mag-view-card-image">
                <div class="mag-view-image-wrapper">
                  <img src="{{fileReference}}" alt="{{title}}" />
                </div>
              </div>
            {{/if}}

            <div class="mag-view-card-body">
              {{#if title}}
                <h3 class="mag-view-card-title">{{title}}</h3>
              {{/if}}

              {{#if text}}
                <div class="mag-view-card-text">{{{text}}}</div>
              {{/if}}

              <div class="mag-view-card-meta">
                {{#if category}}
                  <span class="mag-view-badge">{{category}}</span>
                {{/if}}
                {{#if comments}}
                  <span class="mag-view-meta-stat">
                    <svg
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path
                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                      />
                    </svg>
                    {{comments}}
                  </span>
                {{/if}}
                {{#if views}}
                  <span class="mag-view-meta-stat">
                    <svg
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                      <circle cx="12" cy="12" r="3" />
                    </svg>
                    {{views}}
                  </span>
                {{/if}}
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <!-- List Layout -->
      <div class="mag-view-list">
        {{#each items}}
          <div class="mag-view-list-item">
            <div class="mag-view-list-image">
              <div class="mag-view-image-wrapper">
                {{#if fileReference}}
                  <img src="{{fileReference}}" alt="{{title}}" />
                {{/if}}
              </div>
            </div>

            <div class="mag-view-list-body">
              {{#if title}}
                <h3 class="mag-view-list-title">{{title}}</h3>
              {{/if}}

              <div class="mag-view-list-meta">
                {{#if category}}
                  <span class="mag-view-badge">{{category}}</span>
                {{/if}}
                {{#if date}}
                  <span class="mag-view-meta-date">{{date}}</span>
                {{/if}}
                {{#if comments}}
                  <span class="mag-view-meta-stat">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path
                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                      />
                    </svg>
                    {{comments}}
                  </span>
                {{/if}}
                {{#if views}}
                  <span class="mag-view-meta-stat">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                      <circle cx="12" cy="12" r="3" />
                    </svg>
                    {{views}}
                  </span>
                {{/if}}
              </div>

              {{#if text}}
                <div class="mag-view-list-text">{{{text}}}</div>
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

</div>