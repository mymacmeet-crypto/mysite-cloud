<header class="mag-header" data-component="magheader">

  <!-- Top Utility Bar -->
  <div class="mag-header-top">
    <div class="mag-header-container">
      
      <!-- Left: Social + Subscribe -->
      <div class="mag-header-left">
        {{#if twitterUrl}}
          <a href="{{twitterUrl}}" class="mag-social-link" aria-label="Twitter" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
            </svg>
          </a>
        {{/if}}
        {{#if facebookUrl}}
          <a href="{{facebookUrl}}" class="mag-social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        {{/if}}
        {{#if youtubeUrl}}
          <a href="{{youtubeUrl}}" class="mag-social-link" aria-label="YouTube" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/>
              <polygon fill="#fff" points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
            </svg>
          </a>
        {{/if}}
        {{#if subscribeUrl}}
          <a href="{{subscribeUrl}}" class="mag-subscribe-btn">SUBSCRIBE</a>
        {{/if}}
      </div>

      <!-- Center: Logo -->
      <div class="mag-header-center">
        {{#if logoUrl}}
          <a href="{{logoLink}}" class="mag-logo-link">
            <img src="{{logoUrl}}" alt="{{logoAlt}}" class="mag-logo" />
          </a>
        {{/if}}
      </div>

      <!-- Right: Weather + AA -->
      <div class="mag-header-right">
        {{#if weatherText}}
          <div class="mag-weather">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/>
            </svg>
            <span>{{weatherText}}</span>
          </div>
        {{/if}}
        {{#if aaButtonUrl}}
          <a href="{{aaButtonUrl}}" class="mag-aa-btn" aria-label="Accessibility">
            <span class="mag-aa-text">Aa</span>
          </a>
        {{/if}}
      </div>

    </div>
  </div>

  <!-- Main Navigation Bar -->
  <nav class="mag-header-nav">
    <div class="mag-header-container">

      <!-- Mobile Menu Toggle -->
      <button class="mag-mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="mag-hamburger"></span>
      </button>

      <!-- Logo (Mobile Only) -->
      {{#if logoUrl}}
        <a href="{{logoLink}}" class="mag-logo-mobile">
          <img src="{{logoUrl}}" alt="{{logoAlt}}" />
        </a>
      {{/if}}

      <!-- Navigation Items -->
      <ul class="mag-nav-list">
        {{#each navItems}}
          <li class="mag-nav-item {{#if submenu}}mag-has-dropdown{{/if}}">
            <a href="{{link}}" class="mag-nav-link">{{label}}</a>
            {{#if submenu}}
              <ul class="mag-dropdown">
                {{#each submenu}}
                  <li class="mag-dropdown-item">
                    <a href="{{link}}" class="mag-dropdown-link">{{label}}</a>
                  </li>
                {{/each}}
              </ul>
            {{/if}}
          </li>
        {{/each}}
      </ul>

      <!-- Search -->
      <div class="mag-search">
        <form class="mag-search-form" action="/search" method="GET">
          <input 
            type="search" 
            name="q" 
            class="mag-search-input" 
            placeholder="Search..." 
            aria-label="Search"
          />
          <button type="submit" class="mag-search-btn" aria-label="Submit search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div class="mag-mobile-menu">
    <div class="mag-mobile-menu-header">
      {{#if logoUrl}}
        <img src="{{logoUrl}}" alt="{{logoAlt}}" class="mag-mobile-logo" />
      {{/if}}
      <button class="mag-mobile-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    
    <ul class="mag-mobile-nav">
      {{#each navItems}}
        <li class="mag-mobile-nav-item {{#if submenu}}mag-has-submenu{{/if}}">
          <a href="{{link}}" class="mag-mobile-nav-link">{{label}}</a>
          {{#if submenu}}
            <button class="mag-submenu-toggle" aria-label="Toggle submenu">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <ul class="mag-mobile-submenu">
              {{#each submenu}}
                <li class="mag-mobile-submenu-item">
                  <a href="{{link}}" class="mag-mobile-submenu-link">{{label}}</a>
                </li>
              {{/each}}
            </ul>
          {{/if}}
        </li>
      {{/each}}
    </ul>

    <!-- Mobile Search -->
    <div class="mag-mobile-search">
      <form class="mag-search-form" action="/search" method="GET">
        <input 
          type="search" 
          name="q" 
          class="mag-search-input" 
          placeholder="Search..." 
          aria-label="Search"
        />
        <button type="submit" class="mag-search-btn" aria-label="Submit search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

</header>
