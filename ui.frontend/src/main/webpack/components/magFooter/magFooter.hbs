<footer class="mag-footer" data-component="magfooter">
  <div class="mag-footer-container">

    <!-- Left: Copyright -->
    <div class="mag-footer-left">
      {{#if copyrightText}}
        <p class="mag-footer-copyright">{{{copyrightText}}}</p>
      {{/if}}
    </div>

    <!-- Center: Links -->
    <div class="mag-footer-center">
      {{#each footerLinks}}
        <a href="{{link}}" class="mag-footer-link">
          <svg class="mag-footer-link-arrow" width="8" height="8" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          {{label}}
        </a>
      {{/each}}
    </div>

    <!-- Right: Social Icons -->
    <div class="mag-footer-right">
      {{#if twitterUrl}}
        <a href="{{twitterUrl}}" class="mag-footer-social" aria-label="Twitter" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
          </svg>
        </a>
      {{/if}}
      {{#if facebookUrl}}
        <a href="{{facebookUrl}}" class="mag-footer-social" aria-label="Facebook" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </a>
      {{/if}}
    </div>

  </div>
</footer>
