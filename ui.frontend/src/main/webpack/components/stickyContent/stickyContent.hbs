<div class="sticky-content" data-component="stickycontent">
  <button class="sticky-content__tab" type="button" aria-expanded="false" aria-label="{{tabText}}">
    <span class="sticky-content__tab-text">{{tabText}}</span>
  </button>

  <div class="sticky-content__panel" aria-hidden="true">
    <button class="sticky-content__close" type="button" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="sticky-content__body">
      {{#if heading}}
      <p class="sticky-content__heading">{{heading}}</p>
      {{/if}}
      <form class="sticky-content__form">
        <div class="sticky-content__field">
          <input class="sticky-content__input" type="email" placeholder="{{placeholderText}}" required />
        </div>
        <button class="sticky-content__submit" type="submit">{{buttonText}}</button>
      </form>
    </div>
  </div>
</div>
