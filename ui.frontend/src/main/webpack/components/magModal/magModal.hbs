<div class="mag-modal-wrapper" data-component="magmodal">

  <!-- Trigger Button -->
  {{#if buttonText}}
    <button class="mag-modal-trigger" data-modal-id="{{modalId}}">
      {{buttonText}}
    </button>
  {{/if}}

  <!-- Modal Overlay -->
  <div class="mag-modal-overlay" data-modal-id="{{modalId}}">

    <!-- Modal Container -->
    <div
      class="mag-modal {{modalSize}} {{contentPadding}}"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-title-{{modalId}}"
    >

      <!-- Modal Header -->
      <div class="mag-modal-header">
        {{#if title}}
          <h2
            class="mag-modal-title"
            id="modal-title-{{modalId}}"
          >{{title}}</h2>
        {{/if}}
        <button class="mag-modal-close" aria-label="Close modal">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <!-- Modal Content -->
      <div class="mag-modal-content">
        {{{content}}}
      </div>

    </div>

  </div>

</div>