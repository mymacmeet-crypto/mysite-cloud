<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!--  PROPERTIES TAB                                          -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <propertiesTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <!-- Button Text -->
                            <buttonText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Trigger Button Text"
                                fieldDescription="Text displayed on the button that opens the modal."
                                name="./buttonText"
                                required="{Boolean}true"/>

                            <!-- Modal Title -->
                            <title
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Modal Title"
                                fieldDescription="Title displayed in the modal header."
                                name="./title"/>

                        </items>
                    </propertiesTab>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!--  LAYOUT TAB                                              -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <layoutTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Layout"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <!-- Modal Size -->
                            <modalSize
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Modal Size"
                                fieldDescription="Width of the modal dialog."
                                name="./modalSize">
                                <items jcr:primaryType="nt:unstructured">
                                    <small
                                        jcr:primaryType="nt:unstructured"
                                        text="Small (500px)"
                                        value="mag-modal-size-small"/>
                                    <medium
                                        jcr:primaryType="nt:unstructured"
                                        text="Medium (800px)"
                                        value="mag-modal-size-medium"
                                        selected="{Boolean}true"/>
                                    <large
                                        jcr:primaryType="nt:unstructured"
                                        text="Large (1200px)"
                                        value="mag-modal-size-large"/>
                                    <fullscreen
                                        jcr:primaryType="nt:unstructured"
                                        text="Full Screen"
                                        value="mag-modal-size-fullscreen"/>
                                </items>
                            </modalSize>

                            <!-- Content Padding -->
                            <contentPadding
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Content Padding"
                                fieldDescription="Padding inside the modal content area."
                                name="./contentPadding">
                                <items jcr:primaryType="nt:unstructured">
                                    <none
                                        jcr:primaryType="nt:unstructured"
                                        text="None"
                                        value="mag-modal-padding-none"/>
                                    <small
                                        jcr:primaryType="nt:unstructured"
                                        text="Small (16px)"
                                        value="mag-modal-padding-small"/>
                                    <medium
                                        jcr:primaryType="nt:unstructured"
                                        text="Medium (32px)"
                                        value="mag-modal-padding-medium"
                                        selected="{Boolean}true"/>
                                    <large
                                        jcr:primaryType="nt:unstructured"
                                        text="Large (48px)"
                                        value="mag-modal-padding-large"/>
                                </items>
                            </contentPadding>

                        </items>
                    </layoutTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>