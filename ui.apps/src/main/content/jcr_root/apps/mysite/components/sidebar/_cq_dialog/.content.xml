<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!--  SIDEBAR SETTINGS TAB                                  -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <settingsTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <!-- Sidebar Variant -->
                            <variant
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Variant"
                                fieldDescription="Select the visual style for the sidebar."
                                name="./variant">
                                <items jcr:primaryType="nt:unstructured">
                                    <sidebar
                                        jcr:primaryType="nt:unstructured"
                                        text="Sidebar (Default)"
                                        value="sidebar"
                                        selected="{Boolean}true"/>
                                    <floating
                                        jcr:primaryType="nt:unstructured"
                                        text="Floating"
                                        value="floating"/>
                                    <inset
                                        jcr:primaryType="nt:unstructured"
                                        text="Inset"
                                        value="inset"/>
                                </items>
                            </variant>

                            <!-- Collapsible Mode -->
                            <collapsible
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Collapsible Mode"
                                fieldDescription="Select how the sidebar collapses."
                                name="./collapsible">
                                <items jcr:primaryType="nt:unstructured">
                                    <offcanvas
                                        jcr:primaryType="nt:unstructured"
                                        text="Offcanvas (Default)"
                                        value="offcanvas"
                                        selected="{Boolean}true"/>
                                    <icon
                                        jcr:primaryType="nt:unstructured"
                                        text="Icon"
                                        value="icon"/>
                                    <none
                                        jcr:primaryType="nt:unstructured"
                                        text="None"
                                        value="none"/>
                                </items>
                            </collapsible>

                            <!-- Default Open -->
                            <defaultOpen
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                fieldDescription="Whether the sidebar is expanded by default."
                                name="./defaultOpen"
                                text="Default Open"
                                checked="{Boolean}true"
                                value="{Boolean}true"/>

                        </items>
                    </settingsTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
