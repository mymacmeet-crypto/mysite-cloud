<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!--  MENU ITEMS TAB                                        -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <menuItemsTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Menu Items"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <infoText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/well"
                                text="Add sidebar navigation items. Use the + button to add items and the x button to remove them."/>

                            <menuItemsMultifield
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="Menu Items"
                                fieldDescription="Add or remove sidebar navigation items.">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./menuItem">
                                    <items jcr:primaryType="nt:unstructured">

                                        <label
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Label"
                                            fieldDescription="Display text for the menu item."
                                            name="./label"
                                            required="{Boolean}true"/>

                                        <url
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="URL"
                                            fieldDescription="Link URL or page path."
                                            name="./url"
                                            required="{Boolean}true"/>

                                        <active
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                            fieldDescription="Mark this item as the currently active page."
                                            name="./active"
                                            text="Active"
                                            value="{Boolean}true"
                                            uncheckedValue="{Boolean}false"/>

                                    </items>
                                </field>
                            </menuItemsMultifield>

                        </items>
                    </menuItemsTab>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!--  SIDEBAR SETTINGS TAB                                  -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <settingsTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <variant
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Variant"
                                fieldDescription="Select the visual style for the sidebar."
                                name="./variant">
                                <items jcr:primaryType="nt:unstructured">
                                    <sidebar
                                        jcr:primaryType="nt:unstructured"
                                        text="Sidebar (Default)"
                                        value="sidebar"
                                        selected="{Boolean}true"/>
                                    <floating
                                        jcr:primaryType="nt:unstructured"
                                        text="Floating"
                                        value="floating"/>
                                    <inset
                                        jcr:primaryType="nt:unstructured"
                                        text="Inset"
                                        value="inset"/>
                                </items>
                            </variant>

                            <collapsible
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Collapsible Mode"
                                fieldDescription="Select how the sidebar collapses."
                                name="./collapsible">
                                <items jcr:primaryType="nt:unstructured">
                                    <offcanvas
                                        jcr:primaryType="nt:unstructured"
                                        text="Offcanvas (Default)"
                                        value="offcanvas"
                                        selected="{Boolean}true"/>
                                    <none
                                        jcr:primaryType="nt:unstructured"
                                        text="None"
                                        value="none"/>
                                </items>
                            </collapsible>

                            <defaultOpen
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                fieldDescription="Whether the sidebar is expanded by default."
                                name="./defaultOpen"
                                text="Default Open"
                                checked="{Boolean}true"
                                value="{Boolean}true"
                                uncheckedValue="{Boolean}false"/>

                        </items>
                    </settingsTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
