<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <propertiesTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <!-- TEXTFIELD -->
                            <textfield
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Text Field"
                                fieldDescription="A simple single-line text input"
                                name="./textfield"
                                required="{Boolean}false"
                                maxlength="{Long}100"/>
                            
                            <!-- TEXTAREA -->
                            <textarea
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Text Area"
                                fieldDescription="Multi-line text input"
                                name="./textarea"
                                rows="{Long}5"
                                maxlength="{Long}500"/>
                            
                            <!-- NUMBERFIELD -->
                            <numberfield
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Number Field"
                                fieldDescription="Numeric input with min/max validation"
                                name="./numberfield"
                                min="{Decimal}0"
                                max="{Decimal}100"
                                step="{Decimal}1"/>
                            
                            <!-- PATHFIELD -->
                            <pathfield
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Path Field"
                                fieldDescription="Input for content paths"
                                name="./pathfield"
                                rootPath="/content"/>
                            
                            <!-- PATHBROWSER -->
                            <pathbrowser
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathbrowser"
                                fieldLabel="Path Browser"
                                fieldDescription="Browse and select content paths"
                                name="./pathbrowser"
                                rootPath="/content">
                                <picker
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathbrowser/picker">
                                    <filter
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/pathbrowser/picker/filter"
                                        mode="folder"/>
                                </picker>
                            </pathbrowser> 
                        </items>
                    </propertiesTab>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>